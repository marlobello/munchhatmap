# ─── Discord Bot ──────────────────────────────────────────────────────────────
# Bot token from Discord Developer Portal → Your App → Bot → Token
DISCORD_BOT_TOKEN=

# Trigger tags (comma-separated, case-insensitive)
MAP_TRIGGER_TAGS=#munchhat,#munchhatchronicles

# Public URL of the deployed map (shown in Discord replies after pinning)
MAP_URL=https://munchhatmap.dotheneedful.dev

# ─── Database ─────────────────────────────────────────────────────────────────
# Cosmos DB endpoint and primary key (from Azure Portal → Cosmos DB → Keys)
COSMOS_DB_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_DB_KEY=

# ─── Azure OpenAI ─────────────────────────────────────────────────────────────
# Used for intelligent geocoding from message text and image recognition fallback.
# Get from: Azure Portal → Azure OpenAI → Your resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# ─── Azure Maps ───────────────────────────────────────────────────────────────
# Used for reverse geocoding (EXIF GPS path) and hybrid forward geocoding (text path).
# More accurate and cheaper than AOAI for deterministic coordinate lookups.
# Get from: Azure Portal → Azure Maps → Your account → Authentication
# For local dev, use a subscription key (AZURE_MAPS_KEY).
# In production, managed identity is used instead — set AZURE_MAPS_CLIENT_ID to the
# Maps account's "Client ID" (uniqueId) shown in the Azure Portal Authentication blade.
AZURE_MAPS_KEY=
AZURE_MAPS_CLIENT_ID=

# ─── Azure (for local Functions dev only) ─────────────────────────────────────
# Copy to api/local.settings.json (never commit that file)
AZURE_FUNCTIONS_STORAGE=UseDevelopmentStorage=true
